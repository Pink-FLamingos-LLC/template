{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "app-cron",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-08",
  "triggers": {
    "crons": ["*/5 * * * *"],
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "app-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
    },
  ],
}
