{
  "name": "app-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build && node scripts/patch-worker.js",
    "preview": "vp preview",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage --reporter=verbose",
    "test:watch": "vitest",
    "prepare": "vp config && svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply app-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply app-db --remote",
    "db:studio": "drizzle-kit studio",
    "auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.19",
    "@sentry/sveltekit": "^10.59.0",
    "better-auth": "~1.4.21",
    "drizzle-orm": "^0.45.2",
    "phosphor-svelte": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@cloudflare/vite-plugin": "^1.41.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^4.1.9",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "sveltekit-openapi-generator": "^0.1.6",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.102.0"
  },
  "packageManager": "pnpm@11.6.0"
}
